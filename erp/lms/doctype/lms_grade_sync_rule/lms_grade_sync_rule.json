  {"fieldname": "homeroom_class_log_score_id", "fieldtype": "Link", "label": "Homeroom Score Type", "options": "SIS Class Log Score"},
  {"fieldname": "score_scale_note", "fieldtype": "Small Text", "label": "Score Scale", "description": "LMS điểm % chuyển thang 10 cho Report Card: score * 10 / points_possible", "read_only": 1, "default": "Auto scale to 0-10"}
